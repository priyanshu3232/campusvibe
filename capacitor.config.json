{
  "appId": "com.campusvibe.app",
  "appName": "CampusVibe",
  "webDir": "dist",
  "backgroundColor": "#1A1A2E",
  "android": {
    "backgroundColor": "#1A1A2E",
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": true
  },
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#1A1A2E",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1A1A2E"
    }
  }
}
